# Local .terraform folder (Contains heavy binaries/providers)
.terraform/

# Terraform state files (Contains secrets and sensitive info)
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Terraform variables (Usually contain API keys or passwords)
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include logs
*.log

# Crash logs
crash.log

# CLI configuration files
.terraformrc
terraform.rc